func TestMyServiceService_UpdateMyEntity_Success(t *testing.T) {
	service, db, cleanup := setupMyServiceService(t)
	defer cleanup()

	// Create test data
	entity := testutils.FixtureMyEntity("Old Name")
	db.Create(entity)

	// Create update request
	request := &models.UpdateMyEntityRequest{
		Name: "New Name",
		// Add other fields to update
	}

	// Execute
	result, err := service.UpdateMyEntity(entity.ID, request)

	// Assert
	testutils.AssertNoError(t, err, "UpdateMyEntity should succeed")
	testutils.AssertEqual(t, result.Name, "New Name", "Name should be updated")

	// Verify in database
	var updated models.MyEntity
	db.First(&updated, "id = ?", entity.ID)
	testutils.AssertEqual(t, updated.Name, "New Name", "Should be updated in database")
}

