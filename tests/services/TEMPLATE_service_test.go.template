func TestMyServiceService_DeleteMyEntity_Success(t *testing.T) {
	service, db, cleanup := setupMyServiceService(t)
	defer cleanup()

	// Create test data
	entity := testutils.FixtureMyEntity("Test Entity")
	db.Create(entity)

	// Execute
	err := service.DeleteMyEntity(entity.ID)

	// Assert
	testutils.AssertNoError(t, err, "DeleteMyEntity should succeed")

	// Verify deletion (soft delete check)
	var deleted models.MyEntity
	result := db.Unscoped().First(&deleted, "id = ?", entity.ID)
	testutils.AssertNoError(t, result.Error, "Should find soft-deleted record")
	testutils.AssertNotNil(t, deleted.DeletedAt, "Should be soft-deleted")
}

