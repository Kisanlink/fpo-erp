// setupMyServiceService creates service with all required dependencies
func setupMyServiceService(t *testing.T) (*services.MyServiceService, *gorm.DB, func()) {
	t.Helper()

	// Setup database
	db := testutils.SetupTestDB(t)

	// Create repositories
	// TODO: Add all required repositories for your service
	myEntityRepo := repositories.NewMyEntityRepository(db)
	// dependencyRepo := repositories.NewDependencyRepository(db)

	// Create service
	service := services.NewMyServiceService(myEntityRepo /* , dependencyRepo */)

	// Cleanup function
	cleanup := func() {
		testutils.CleanupTestDB(db)
	}

	return service, db, cleanup
}

