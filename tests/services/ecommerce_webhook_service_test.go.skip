func TestEcommerceWebhookService_ProcessOrderPayment_FullPayment(t *testing.T) {
n	// Setup
	tdb := testutils.SetupTestDB(t)
	defer tdb.TeardownTestDB(t)
n	mockAAA := testutils.NewMockAAAClient()

	mockAAA := testutils.NewMockAAAClient()
	// Setup
	tdb := testutils.SetupTestDB(t)
	defer tdb.TeardownTestDB(t)
n	mockAAA := testutils.NewMockAAAClient()

	// Create test PO
	collaborator := testutils.CreateTestCollaborator(tdb.DB, "Test Supplier", "27AABCU9603R1ZM")
	po := testutils.CreateTestPurchaseOrder(tdb.DB, collaborator.ID, 5000.0, "confirmed")
	externalOrderID := "ECOM_ORD_PAY_001"
	po.ExternalOrderID = &externalOrderID
	tdb.DB.Save(po)

	// Setup repositories
	collaboratorRepo := repositories.NewCollaboratorRepository(tdb.DB)
	productRepo := repositories.NewProductRepository(tdb.DB)
	variantRepo := repositories.NewProductVariantRepository(tdb.DB)
	warehouseRepo := repositories.NewWarehouseRepository(tdb.DB)
	grnRepo := repositories.NewGRNRepository(tdb.DB)
	inventoryRepo := repositories.NewInventoryRepository(tdb.DB)
	poRepo := repositories.NewPurchaseOrderRepository(tdb.DB)

	poService := services.NewPurchaseOrderService(poRepo, collaboratorRepo, warehouseRepo, productRepo, variantRepo, grnRepo, inventoryRepo)
	webhookService := services.NewEcommerceWebhookService(
		poService,
		collaboratorRepo,
		productRepo,
		variantRepo,
		warehouseRepo,
		grnRepo,
		inventoryRepo,
		poRepo,
		nil, // addressClient not used in webhook service
	)

	// Create webhook payload with full payment
	webhook := &models.OrderPaymentWebhook{
		ExternalOrderID: externalOrderID,
		PaidAmount:      5000.0,
	}

	// Execute
	ctx := testutils.CreateTestContext()
	err := webhookService.ProcessOrderPayment(ctx, webhook)

	// Assert
	testutils.AssertNoError(t, err, "ProcessOrderPayment should succeed")

	// Verify payment status updated
	updatedPO, _ := poRepo.GetByID(po.ID)
	testutils.AssertEqual(t, updatedPO.PaymentStatus, "paid", "Payment status should be paid")
	testutils.AssertEqual(t, updatedPO.PaidAmount, 5000.0, "Paid amount should match")
}

