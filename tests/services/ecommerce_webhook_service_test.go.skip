func TestEcommerceWebhookService_ProcessOrderCreated_SmartVariantMatching_ByExternalID(t *testing.T) {
n	// Setup
	tdb := testutils.SetupTestDB(t)
	defer tdb.TeardownTestDB(t)
n	mockAAA := testutils.NewMockAAAClient()

	mockAAA := testutils.NewMockAAAClient()
	// Setup
	tdb := testutils.SetupTestDB(t)
	defer tdb.TeardownTestDB(t)
n	mockAAA := testutils.NewMockAAAClient()


	addressReq := &aaa.CreateAddressRequest{
		UserID:    "test-user",
		Type:      "WORK",
		IsPrimary: true,
	}
	pincode := "400001"
	addressReq.Pincode = &pincode
	address, _ := mockAAA.CreateAddress(context.Background(), addressReq, "test-jwt")

	warehouse := testutils.CreateTestWarehouse(tdb.DB, "Test Warehouse")
	warehouse.AddressID = &address.ID
	tdb.DB.Save(warehouse)

	// Pre-create product and variant with external_id
	product := testutils.CreateTestProduct(tdb.DB, "Existing Product", "Description")
	variant := testutils.CreateTestProductVariant(tdb.DB, product.ID, "Existing Variant", "SKU-EXISTING")
	externalID := "EXISTING_VAR_001"
	variant.ExternalID = &externalID
	tdb.DB.Save(variant)

	// Setup repositories
	collaboratorRepo := repositories.NewCollaboratorRepository(tdb.DB)
	productRepo := repositories.NewProductRepository(tdb.DB)
	variantRepo := repositories.NewProductVariantRepository(tdb.DB)
	warehouseRepo := repositories.NewWarehouseRepository(tdb.DB)
	grnRepo := repositories.NewGRNRepository(tdb.DB)
	inventoryRepo := repositories.NewInventoryRepository(tdb.DB)
	poRepo := repositories.NewPurchaseOrderRepository(tdb.DB)

	poService := services.NewPurchaseOrderService(poRepo, collaboratorRepo, warehouseRepo, productRepo, variantRepo, grnRepo, inventoryRepo)
	webhookService := services.NewEcommerceWebhookService(
		poService,
		collaboratorRepo,
		productRepo,
		variantRepo,
		warehouseRepo,
		grnRepo,
		inventoryRepo,
		poRepo,
		nil, // addressClient not used in webhook service
	)

	// Webhook referencing existing variant by external_id
	orderDate := time.Now().Format(time.RFC3339)
	expectedDelivery := time.Now().AddDate(0, 0, 7).Format(time.RFC3339)

	webhook := &models.OrderCreatedWebhook{
		Order: models.WebhookOrder{
			ExternalOrderID:      "ECOM_ORD_005",
			OrderDate:            &orderDate,
			ExpectedDeliveryDate: expectedDelivery,
		},
		FPO: models.WebhookFPO{
			DeliveryAddress: models.WebhookAddress{
				AddressID: address.ID,
			},
		},
		Collaborator: models.WebhookCollaborator{
			ExternalID:     "COLLAB_005",
			CompanyName:    "Test Supplier",
			ContactPerson:  "John Doe",
			ContactNumber:  "+91-9876543210",
			BankAccountNo:  "123456789",
			BankIFSC:       "SBIN0001234",
			AddressID:      &address.ID,
		},
		Items: []models.WebhookOrderItem{
			{
				Product: models.WebhookProduct{
					ExternalID:  "PROD_EXISTING",
					Name:        "Existing Product",
					Description: stringPtr("Description"),
				},
				Variant: models.WebhookVariant{
					ExternalID: "EXISTING_VAR_001", // Match by external_id
					Name:       "Existing Variant",
					SKU:        "SKU-EXISTING",
				},
				Quantity:  100,
				UnitPrice: 50.00,
			},
		},
	}

	// Execute
	ctx := testutils.CreateTestContext()
	_, err := webhookService.ProcessOrderCreated(ctx, webhook)
	testutils.AssertNoError(t, err, "Should match variant by external_id")

	// Verify no duplicate variant was created (smart matching worked)
	variants, _ := variantRepo.GetAll()
	// Should still have only 1 variant (the pre-created one)
	testutils.AssertEqual(t, len(variants), 1, "Should not create duplicate variant")
}

func TestEcommerceWebhookService_ProcessOrderCreated_SmartVariantMatching_BySKU(t *testing.T) {
n	// Setup
	tdb := testutils.SetupTestDB(t)
	defer tdb.TeardownTestDB(t)
n	mockAAA := testutils.NewMockAAAClient()

	mockAAA := testutils.NewMockAAAClient()
	// Setup
	tdb := testutils.SetupTestDB(t)
	defer tdb.TeardownTestDB(t)
n	mockAAA := testutils.NewMockAAAClient()


	addressReq := &aaa.CreateAddressRequest{
		UserID:    "test-user",
		Type:      "WORK",
		IsPrimary: true,
	}
	pincode := "400001"
	addressReq.Pincode = &pincode
	address, _ := mockAAA.CreateAddress(context.Background(), addressReq, "test-jwt")

	warehouse := testutils.CreateTestWarehouse(tdb.DB, "Test Warehouse")
	warehouse.AddressID = &address.ID
	tdb.DB.Save(warehouse)

	// Pre-create product and variant with SKU but NO external_id
	product := testutils.CreateTestProduct(tdb.DB, "Existing Product", "Description")
	variant := testutils.CreateTestProductVariant(tdb.DB, product.ID, "Existing Variant", "SKU-MATCH-TEST")
	// NO external_id set, so smart matching should fall back to SKU

	// Setup repositories
	collaboratorRepo := repositories.NewCollaboratorRepository(tdb.DB)
	productRepo := repositories.NewProductRepository(tdb.DB)
	variantRepo := repositories.NewProductVariantRepository(tdb.DB)
	warehouseRepo := repositories.NewWarehouseRepository(tdb.DB)
	grnRepo := repositories.NewGRNRepository(tdb.DB)
	inventoryRepo := repositories.NewInventoryRepository(tdb.DB)
	poRepo := repositories.NewPurchaseOrderRepository(tdb.DB)

	poService := services.NewPurchaseOrderService(poRepo, collaboratorRepo, warehouseRepo, productRepo, variantRepo, grnRepo, inventoryRepo)
	webhookService := services.NewEcommerceWebhookService(
		poService,
		collaboratorRepo,
		productRepo,
		variantRepo,
		warehouseRepo,
		grnRepo,
		inventoryRepo,
		poRepo,
		nil, // addressClient not used in webhook service
	)

	// Webhook with new external_id but matching SKU
	orderDate := time.Now().Format(time.RFC3339)
	expectedDelivery := time.Now().AddDate(0, 0, 7).Format(time.RFC3339)

	webhook := &models.OrderCreatedWebhook{
		Order: models.WebhookOrder{
			ExternalOrderID:      "ECOM_ORD_006",
			OrderDate:            &orderDate,
			ExpectedDeliveryDate: expectedDelivery,
		},
		FPO: models.WebhookFPO{
			DeliveryAddress: models.WebhookAddress{
				AddressID: address.ID,
			},
		},
		Collaborator: models.WebhookCollaborator{
			ExternalID:     "COLLAB_006",
			CompanyName:    "Test Supplier",
			ContactPerson:  "John Doe",
			ContactNumber:  "+91-9876543210",
			BankAccountNo:  "123456789",
			BankIFSC:       "SBIN0001234",
			AddressID:      &address.ID,
		},
		Items: []models.WebhookOrderItem{
			{
				Product: models.WebhookProduct{
					ExternalID:  "PROD_006",
					Name:        "Existing Product",
					Description: stringPtr("Description"),
				},
				Variant: models.WebhookVariant{
					ExternalID: "NEW_EXTERNAL_ID_006", // New external_id
					Name:       "Existing Variant",
					SKU:        "SKU-MATCH-TEST", // But matching SKU
				},
				Quantity:  100,
				UnitPrice: 50.00,
			},
		},
	}

	// Execute
	ctx := testutils.CreateTestContext()
	_, err := webhookService.ProcessOrderCreated(ctx, webhook)
	testutils.AssertNoError(t, err, "Should match variant by SKU")

	// Verify variant was matched and external_id was updated
	updatedVariant, _ := variantRepo.GetByID(variant.ID)
	testutils.AssertEqual(t, *updatedVariant.ExternalID, "NEW_EXTERNAL_ID_006", "External ID should be updated")
}

