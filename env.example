# =============================================================================
# KISANLINK ERP - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update the values according to your environment
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# HTTP server port
SERVER_HTTP_PORT=3000

# Gin framework mode (debug, release, test)
SERVER_MODE=release

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database connection
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_USER=kisanlink
DB_POSTGRES_PASSWORD=your_secure_password_here
DB_POSTGRES_DBNAME=kisanlink_erp
DB_POSTGRES_SSLMODE=disable
DB_AUTO_MIGRATE=true

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT secret for token validation (use a strong, random secret)
JWT_SECRET=your_super_secure_jwt_secret_key_here_minimum_32_characters

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# =============================================================================
# AAA SERVICE CONFIGURATION
# =============================================================================
# Enable/disable AAA authentication (true = enabled, false = bypass mode for local testing)
# WARNING: Set to false ONLY for development/testing. Never disable in production.
AAA_ENABLED=true

# JWT secret for AAA service token validation
AAA_JWT_SECRET=your_aaa_jwt_secret_key_here_minimum_32_characters

# AAA service gRPC address (for authorization)
AAA_GRPC_ADDRESS=localhost:50051

# AAA service timeout in seconds
AAA_TIMEOUT_SECONDS=30

# AAA permission cache TTL in seconds
AAA_CACHE_TTL=300

# =============================================================================
# AWS S3 CONFIGURATION (for file attachments)
# =============================================================================
# AWS region
AWS_REGION=us-east-1

# AWS access credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 bucket name for file storage
AWS_S3_BUCKET=kisanlink-attachments

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://app.kisanlink.com

# CORS allowed headers (comma-separated)
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-Requested-With

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# =============================================================================
# WEBHOOK CONFIGURATION (E-commerce Integration)
# =============================================================================
# Webhook shared secret for HMAC-SHA256 signature verification
# IMPORTANT: This must match the secret configured in the e-commerce platform
# Use a strong, random secret (minimum 32 characters recommended)
WEBHOOK_SECRET=your_webhook_secret_shared_with_ecommerce_platform

# Webhook processing timeout in seconds (default: 30)
# Maximum time to process a webhook before timing out
WEBHOOK_TIMEOUT_SECONDS=30

# Maximum webhook payload size in bytes (default: 10MB)
# Protects against excessively large webhook requests
WEBHOOK_MAX_PAYLOAD_BYTES=10485760

# =============================================================================
# END OF CONFIGURATION
# =============================================================================


# =============================================================================
# E-COMMERCE SERVICE CONFIGURATION (gRPC)
# =============================================================================

ECOMMERCE_ENABLED=false

# E-commerce service gRPC address (host:port)
# Example: localhost:50052, ecommerce.yourdomain.com:443
# Leave empty to disable e-commerce integration (will use legacy AAA address service)
ECOMMERCE_GRPC_ADDRESS=localhost:50052

# gRPC connection timeout in seconds (default: 5)
ECOMMERCE_GRPC_TIMEOUT_SECONDS=5

# Optional: Authentication token for e-commerce service
# ECOMMERCE_GRPC_AUTH_TOKEN=your_ecommerce_auth_token_here

# Optional: Enable TLS for secure gRPC connection (true/false, default: false)
ECOMMERCE_GRPC_USE_TLS=false

# Optional: TLS certificate paths (only required if ECOMMERCE_GRPC_USE_TLS=true)
# ECOMMERCE_GRPC_CA_CERT=/path/to/ca-cert.pem
# ECOMMERCE_GRPC_CLIENT_CERT=/path/to/client-cert.pem
# ECOMMERCE_GRPC_CLIENT_KEY=/path/to/client-key.pem

