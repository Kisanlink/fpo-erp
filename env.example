# =============================================================================
# KISANLINK ERP - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update the values according to your environment
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# HTTP server port
SERVER_HTTP_PORT=8080

# Gin framework mode (debug, release, test)
SERVER_MODE=release

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database connection
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_USER=kisanlink
DB_POSTGRES_PASSWORD=your_secure_password_here
DB_POSTGRES_DBNAME=kisanlink_erp
DB_POSTGRES_SSLMODE=disable

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT secret for token validation (use a strong, random secret)
JWT_SECRET=your_super_secure_jwt_secret_key_here_minimum_32_characters

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# =============================================================================
# AAA SERVICE CONFIGURATION
# =============================================================================
# JWT secret for AAA service token validation
AAA_JWT_SECRET=your_aaa_jwt_secret_key_here_minimum_32_characters

# AAA service HTTP URL
AAA_SERVICE_URL=http://localhost:8081

# AAA service gRPC address
AAA_GRPC_ADDRESS=localhost:50051

# AAA service timeout in seconds
AAA_TIMEOUT_SECONDS=30

# AAA permission cache TTL in seconds
AAA_CACHE_TTL=300

# =============================================================================
# AWS S3 CONFIGURATION (for file attachments)
# =============================================================================
# AWS region
AWS_REGION=us-east-1

# AWS access credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 bucket name for file storage
AWS_S3_BUCKET=kisanlink-attachments

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://app.kisanlink.com

# CORS allowed headers (comma-separated)
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-Requested-With

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# =============================================================================
# END OF CONFIGURATION
# =============================================================================

